# HTTP and access control
PROPULSE_HTTP_ADDR=:8080
PROPULSE_ACCESS_TOKEN=replace-with-a-long-random-token

# Stable user identity (required; app fails fast if unset)
PROPULSE_USER_ID=propulse-user

# Capacity city policy (all five are required for serve/api/worker/scheduler)
PROPULSE_CAPACITY_POLICY_CITY=replace-with-current-city
PROPULSE_CAPACITY_POLICY_NAME=replace-with-policy-name
PROPULSE_CAPACITY_POLICY_DOWN_PAYMENT_RATE=0.35
PROPULSE_CAPACITY_POLICY_EFFECTIVE_DATE=2026-07-14
PROPULSE_CAPACITY_POLICY_SOURCE=replace-with-authoritative-policy-source

# PostgreSQL and Redis
PROPULSE_DATABASE_URL=postgres://propulse:propulse@127.0.0.1:5432/propulse?sslmode=disable
PROPULSE_REDIS_ADDR=127.0.0.1:6379

# Docker Compose host ports and PostgreSQL bootstrap credentials
PROPULSE_BIND_ADDRESS=127.0.0.1
PROPULSE_HTTP_PORT=8317
PROPULSE_POSTGRES_PORT=15432
PROPULSE_REDIS_PORT=16379
PROPULSE_POSTGRES_USER=propulse
PROPULSE_POSTGRES_PASSWORD=propulse
PROPULSE_POSTGRES_DB=propulse

# Runtime behavior
PROPULSE_SCHEDULER_INTERVAL=1h

# Logging
PROPULSE_LOG_LEVEL=info
PROPULSE_LOG_PRETTY=false

# Optional integration test targets
PROPULSE_TEST_DATABASE_URL=
PROPULSE_E2E_BASE_URL=
PROPULSE_E2E_ACCESS_TOKEN=
